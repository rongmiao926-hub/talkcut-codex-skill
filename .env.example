# Leave blank to ask every time.
ASR_ENGINE=

# Required when ASR_ENGINE=volcengine
VOLCENGINE_API_KEY=

# Optional. If blank, default to a sibling output/ directory next to the source video.
DEFAULT_OUTPUT_DIR=

# Keep extra audio around each delete boundary to avoid clipping nearby words.
# Increase to 1000 if the end of kept speech still gets swallowed.
CUT_KEEP_PADDING_MS=500

# Always leave at least this much selected audio deleted after shrinking.
# This prevents very short selections from becoming "nothing gets cut".
CUT_MIN_DELETE_MS=120

# Optional local server ports
REVIEW_PORT=8899
SUBTITLE_PORT=8898
