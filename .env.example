# Leave blank to ask every time.
ASR_ENGINE=

# Required when ASR_ENGINE=volcengine
VOLCENGINE_API_KEY=

# Optional. If blank, default to a sibling output/ directory next to the source video.
DEFAULT_OUTPUT_DIR=

# Keep a little extra audio around detected kept speech boundaries.
# Default is 0 so manual review exports follow the selected ranges exactly.
# Increase only if the end of kept speech still gets swallowed.
CUT_KEEP_PADDING_MS=0

# Always leave at least this much selected audio deleted after shrinking.
# This prevents very short selections from becoming "nothing gets cut".
CUT_MIN_DELETE_MS=120

# Optional. Extra expansion around the final delete range.
CUT_EXPAND_MS=0

# Optional. Audio edge fade to smooth joins without shortening total duration.
CROSSFADE_MS=30

# Optional local server ports
REVIEW_PORT=8899
SUBTITLE_PORT=8898
